{
  "name": "ai-code-reviewer",
  "displayName": "AI Code Reviewer",
  "description": "AI-powered code review tool",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ai-code-reviewer"
  },
  "icon": "icon.png",
  "categories": [
    "Other",
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-review.analyze",
        "title": "AI Code Review: Analyze Selection/File"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "code-review.analyze",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "code-review.analyze",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/glob": "^8.1.0",
    "@types/node": "20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
